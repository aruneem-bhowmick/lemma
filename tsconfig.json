{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": ["scripts/**/*", "tests/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
