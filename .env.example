# Microsoft Graph / Azure AD
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
GRAPH_REFRESH_TOKEN=          # long-lived; see docs/auth-setup.md
ONENOTE_NOTEBOOK_ID=          # from Graph API /me/onenote/notebooks

# Database
DATABASE_URL=                  # postgres://user:pass@host/dbname

# Vision model (from spike winner)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                # fallback
MATHPIX_APP_ID=                # optional, for math routing
MATHPIX_APP_KEY=               # optional

# Pipeline behaviour
CORPUS_DIR=./corpus
ASSETS_DIR=./assets
DRY_RUN=false                  # if true, skip writes and DB updates
MAX_CONCURRENT_PAGES=3         # parallel vision calls in flight

# Rendering strategy
RENDER_STRATEGY=pdf-export     # pdf-export | semi-auto | inkml-raster
SEMI_AUTO_DROP_DIR=            # directory to watch for exported PDFs (semi-auto strategy)
SEMI_AUTO_TIMEOUT_MS=0         # ms to wait for a file in drop dir; 0 = check once

# Vision model override
VISION_MODEL=claude-sonnet-4-6 # model id passed to the vision client

# Logging
LOG_LEVEL=info                 # info | debug | warn | error

# Testing
E2E=                           # set to true to run end-to-end tests
TEST_DATABASE_URL=             # postgres URL for integration test isolation
